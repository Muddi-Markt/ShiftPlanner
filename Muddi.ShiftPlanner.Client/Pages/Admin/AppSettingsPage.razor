@page "/admin/app-settings"
@attribute [Authorize(Policy = @Policies.IsSuperAdmin)]
@using Muddi.ShiftPlanner.Shared.BlazorWASM
@inject AppSettingsService AppSettingsService
@inject NotificationService NotificationService
@implements IDisposable

<RadzenText TextStyle="TextStyle.H4">Globale Einstellungen</RadzenText>
<RadzenText TextStyle="TextStyle.Body1">Definiere die Standard-Zeiten und allgemeine Einstellungen.</RadzenText>

<div class="row mt-4">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Titel"/>
    </div>
    <div class="col-md-8">
        <RadzenTextBox @bind-Value="_settings.Title"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Untertitel"/>
    </div>
    <div class="col-md-8">
        <RadzenTextBox @bind-Value="_settings.Subtitle"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Kontakt-Email"/>
    </div>
    <div class="col-md-8">
        <RadzenTextBox @bind-Value="_settings.Contact"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Grüßwort"/>
    </div>
    <div class="col-md-8">
        <RadzenTextBox @bind-Value="_settings.Greeting"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Mitglieder-Name"/>
    </div>
    <div class="col-md-8">
        <RadzenTextBox @bind-Value="_settings.MemberName"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Startzeit"/>
    </div>
    <div class="col-md-8">
        <RadzenTimeSpanPicker @bind-Value="_settings.StartTime"/>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-4 align-items-center d-flex">
        <RadzenLabel Text="Endzeit"/>
    </div>
    <div class="col-md-8">
        <RadzenTimeSpanPicker @bind-Value="_settings.EndTime"/>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12 text-right">
        <RadzenButton Click="Save" ButtonStyle="ButtonStyle.Success" Text="Speichern"/>
        <RadzenButton Click="Cancel" ButtonStyle="ButtonStyle.Danger" Text="Abbrechen" Class="mr-1"/>
    </div>
</div>

@code {
    private ApplicationSettings _settings = new();
    private ApplicationSettings _original = new();

    protected override async Task OnInitializedAsync()
    {
        _settings = await AppSettingsService.GetSettingsAsync();
        _original = new ApplicationSettings
        {
            Title = _settings.Title,
            Subtitle = _settings.Subtitle,
            Contact = _settings.Contact,
            StartTime = _settings.StartTime,
            EndTime = _settings.EndTime,
            Greeting = _settings.Greeting,
            MemberName = _settings.MemberName
        };
        AppSettingsService.SettingsChanged += OnSettingsChanged;
    }

    private void OnSettingsChanged(object? sender, ApplicationSettings applicationSettings)
    {
        _settings = applicationSettings;
        InvokeAsync(StateHasChanged);
    }

    private async Task Save()
    {
        try
        {
            await AppSettingsService.UpdateAsync(_settings);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Erfolgreich",
                Detail = "Einstellungen gespeichert.",
                Duration = 3000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Fehler",
                Detail = $"Fehler beim Speichern: {ex.Message}",
                Duration = 5000
            });
        }
    }

    private void Cancel()
    {
        _settings = new ApplicationSettings
        {
            Title = _original.Title,
            Subtitle = _original.Subtitle,
            Contact = _original.Contact,
            StartTime = _original.StartTime,
            EndTime = _original.EndTime,
            Greeting = _original.Greeting,
            MemberName = _original.MemberName
        };
    }

    public void Dispose()
    {
        AppSettingsService.SettingsChanged -= OnSettingsChanged;
    }
}
