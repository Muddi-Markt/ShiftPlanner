@page "/"
@using Muddi.ShiftPlanner.Client.Pages.Statistics
@attribute [Authorize]
@inject AppSettingsService AppSettingsService;
<AuthorizeView>
	<Authorized>
		<h2>@AppSettingsService.Current.Greeting @(context.User.Identity?.Name)!</h2>
		<br/>
		<StatisticsDashboardComponent/>
		<DisplayNextShiftsComponent/>
		<br/>
		<p>Wenn du Hilfe benötigst wendest du dich am Besten an <a href="@AppSettingsService.Current.ContactHref">@AppSettingsService.Current.Contact</a></p>
	</Authorized>

	<NotAuthorized>
		Du bist nicht eingeloggt!
		<a href="/authentication/login">Login</a>
	</NotAuthorized>
</AuthorizeView>